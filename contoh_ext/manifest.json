{
  "manifest_version": 3,
  "name": "Ghost Hands",
  "version": "0.8.5",
  "description": "Automation tool: click, scroll, type with remote config",
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "sidePanel",
    "tabs"
  ],
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "js/content/webSocketMonitor.js"
      ],
      "run_at": "document_start",
      "world": "MAIN"
    }
  ],
  "host_permissions": [
    "https://script.google.com/*",
    "https://api.trakteer.id/*",
    "<all_urls>"
  ],
  "background": {
    "service_worker": "js/background.js"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "action": {
    "default_title": "Ghost Hands"
  },
  "icons": {
    "16": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  }
}