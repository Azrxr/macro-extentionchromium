{
  "manifest_version": 3,
  "name": "Magerin",
  "version": "1.0.0",
  "description": "RPA Browser Automation Extension with Glassmorphic Dark UI",
  "permissions": [
    "storage",
    "tabs",
    "scripting",
    "sidePanel",
    "activeTab"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "js/background.js"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "action": {
    "default_title": "Open Magerin"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["js/content.js"],
      "all_frames": true
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "sidepanel.html",
        "sidepanel.css",
        "js/sidepanel.js"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ]
}
